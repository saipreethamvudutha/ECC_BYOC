generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS / ORGANIZATIONS ─────────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter") // starter, pro, enterprise
  settings  String   @default("{}") // JSON settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  roles       Role[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
  invitations Invitation[]
  assets      Asset[]
  scans       Scan[]
  scanResults ScanResult[]
  complianceFrameworks ComplianceFramework[]
  complianceControls   ComplianceControl[]
  complianceAssessments ComplianceAssessment[]
  siemEvents    SiemEvent[]
  siemAlerts    SiemAlert[]
  siemRules     SiemRule[]
  siemIncidents SiemIncident[]
  aiActions   AiAction[]
  reports     Report[]
  assetGroups AssetGroup[]
  tags         Tag[]
  scopes       Scope[]
  autoTagRules AutoTagRule[]
  sessions     Session[]
  ssoProviders SSOProvider[]
  scimTokens   SCIMToken[]
  credentialVaults      CredentialVault[]
  scanTargetCredentials ScanTargetCredential[]
  scanDiffs             ScanDiff[]

  @@map("tenants")
}

// ─── USERS ───────────────────────────────────────────────────────
model User {
  id             String    @id @default(uuid())
  tenantId       String
  email          String
  name           String
  passwordHash   String?
  authProvider   String    @default("local") // local, google, azure_ad, okta
  authProviderId String?
  status         String    @default("active") // active, invited, suspended, deactivated
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  mfaBackupCodes String?   // JSON: hashed backup codes
  lastLoginAt         DateTime?
  lastLoginIp         String?
  avatarUrl           String?
  department          String?
  phone               String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  createdRoles   Role[]          @relation("RoleCreator")
  apiKeys        ApiKey[]        @relation("ApiKeyCreator")
  invitedBy      Invitation[]    @relation("InvitedBy")
  auditLogs      AuditLog[]      @relation("AuditActor")
  assignedRoles  UserRole[]      @relation("RoleAssigner")
  userScopes          UserScope[]
  createdScopes       Scope[]         @relation("ScopeCreator")
  createdAutoTagRules AutoTagRule[]   @relation("AutoTagRuleCreator")
  sessions            Session[]
  createdSSOProviders SSOProvider[]   @relation("SSOProviderCreator")
  createdSCIMTokens   SCIMToken[]    @relation("SCIMTokenCreator")
  createdCredentials  CredentialVault[] @relation("CredentialCreator")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// ═══════════════════════════════════════════════════════════════════
// RBAC v2: TWO-AXIS MODEL (Functional Roles + Data Scopes)
// ═══════════════════════════════════════════════════════════════════

// ─── CAPABILITIES (system-wide, not tenant-specific) ─────────────
// Replaces the flat Permission model. 39 capabilities across 8 modules.
model Capability {
  id          String @id // e.g. 'scan.execute' — human-readable, stable
  module      String // e.g. 'scan', 'asset', 'admin'
  name        String // e.g. 'Execute Scans'
  description String?
  riskLevel   String @default("low") // low, medium, high, critical

  roleCapabilities RoleCapability[]

  @@index([module])
  @@map("capabilities")
}

// ─── ROLES ───────────────────────────────────────────────────────
model Role {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  slug            String
  description     String?
  isBuiltin       Boolean  @default(false)
  isActive        Boolean  @default(true)
  parentRoleId    String?
  maxAssignments  Int?     // e.g. 2 for Platform Admin
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentRole       Role?             @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles       Role[]            @relation("RoleHierarchy")
  createdBy        User?             @relation("RoleCreator", fields: [createdById], references: [id])
  roleCapabilities RoleCapability[]
  userRoles        UserRole[]
  apiKeys          ApiKey[]
  invitations      Invitation[]

  @@unique([tenantId, slug])
  @@map("roles")
}

// ─── ROLE <-> CAPABILITY MAPPING (v2) ────────────────────────────
model RoleCapability {
  roleId       String
  capabilityId String
  granted      Boolean @default(true) // false = explicit deny (override layer)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([roleId, capabilityId])
  @@index([roleId])
  @@map("role_capabilities")
}

// ─── USER <-> ROLE MAPPING (many-to-many, cumulative) ────────────
model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  assignedBy String?
  assignedAt DateTime  @default(now())
  expiresAt  DateTime?

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("RoleAssigner", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

// ═══════════════════════════════════════════════════════════════════
// DATA SCOPING (Axis 2) — Tag-Based Access
// ═══════════════════════════════════════════════════════════════════

// ─── TAGS ────────────────────────────────────────────────────────
model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  key       String   // e.g. 'env', 'region', 'team'
  value     String   // e.g. 'production', 'mumbai'
  color     String?  // hex color for UI
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetTags    AssetTag[]
  autoTagRules AutoTagRule[]

  @@unique([tenantId, key, value])
  @@index([tenantId, key])
  @@map("tags")
}

// ─── ASSET <-> TAG MAPPING ───────────────────────────────────────
model AssetTag {
  assetId   String
  tagId     String
  appliedBy String   @default("manual") // manual, auto_rule, discovery
  appliedAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@index([assetId])
  @@index([tagId])
  @@map("asset_tags")
}

// ─── SCOPES (named tag filter sets) ──────────────────────────────
model Scope {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  tagFilter   String   @default("{}") // JSON: {"env": ["production"], "region": ["mumbai"]}
  isGlobal    Boolean  @default(false) // true = matches all assets
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User?       @relation("ScopeCreator", fields: [createdById], references: [id])
  userScopes UserScope[]

  @@unique([tenantId, name])
  @@map("scopes")
}

// ─── USER <-> SCOPE MAPPING (many-to-many, union) ────────────────
model UserScope {
  userId     String
  scopeId    String
  assignedBy String?
  assignedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope Scope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@id([userId, scopeId])
  @@index([userId])
  @@map("user_scopes")
}

// ─── AUTO-TAG RULES (Phase 2) ──────────────────────────────────
model AutoTagRule {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  condition   String   @default("{}") // JSON: {"field":"type","operator":"equals","value":"server"}
  tagId       String
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tag       Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("AutoTagRuleCreator", fields: [createdById], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("auto_tag_rules")
}

// ═══════════════════════════════════════════════════════════════════
// EXISTING MODELS (unchanged from v1)
// ═══════════════════════════════════════════════════════════════════

// ─── API KEYS ────────────────────────────────────────────────────
model ApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  keyHash     String
  keyPrefix   String
  roleId      String
  createdById String
  ipAllowlist String?   // JSON array of IPs
  rateLimit   Int       @default(1000)
  lastUsedAt  DateTime?
  expiresAt   DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id])
  createdBy User   @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@unique([tenantId, name])
  @@map("api_keys")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────
model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  actorId       String?
  actorType     String   // user, api_key, system, ai_agent
  action        String   // e.g. 'role.assigned', 'scan.executed'
  resourceType  String?
  resourceId    String?
  details       String   @default("{}") // JSON
  ipAddress     String?
  userAgent     String?
  result        String   // success, denied, error
  category      String?  // auth, rbac, data, admin, security, system
  severity      String   @default("info") // info, low, medium, high, critical
  integrityHash String?  // SHA-256 hash chain for tamper detection
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation("AuditActor", fields: [actorId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([tenantId, action])
  @@index([tenantId, category])
  @@map("audit_log")
}

// ─── SESSIONS ────────────────────────────────────────────────────
model Session {
  id           String    @id @default(uuid())
  tenantId     String
  userId       String
  tokenHash    String    // SHA-256 hash of refresh token
  ipAddress    String?
  userAgent    String?
  device       String?   // parsed from user-agent: "Chrome on Windows"
  city         String?   // derived from IP (future: GeoIP)
  country      String?
  isActive     Boolean   @default(true)
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  revokedBy    String?   // userId who revoked
  createdAt    DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([tenantId, isActive])
  @@index([tokenHash])
  @@map("sessions")
}

// ─── INVITATIONS ─────────────────────────────────────────────────
model Invitation {
  id          String   @id @default(uuid())
  tenantId    String
  email       String
  roleId      String
  invitedById String
  tokenHash   String
  tokenPrefix String?  // first 8 chars for efficient lookup
  status      String   @default("pending") // pending, accepted, expired, revoked
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id])
  invitedBy User   @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([tokenPrefix, status])
  @@map("invitations")
}

// ─── ASSETS ──────────────────────────────────────────────────────
model AssetGroup {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([tenantId, slug])
  @@map("asset_groups")
}

model Asset {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  type         String   // server, workstation, network_device, cloud_resource, application, database, container, iot_device
  ipAddress    String?
  hostname     String?
  os           String?
  criticality  String   @default("medium") // critical, high, medium, low
  status       String   @default("active") // active, inactive, decommissioned
  tags         String   @default("[]") // JSON array (legacy, kept for backward compat)
  metadata     String   @default("{}") // JSON
  groupId      String?
  lastScanAt   DateTime?
  // ── Phase 8: Asset Discovery Fields ──
  macAddress      String?  // MAC address if discoverable (ARP/SNMP)
  manufacturer    String?  // Hardware vendor (e.g., "Cisco", "Dell", "AWS")
  model           String?  // Device model (e.g., "Catalyst 9300", "PowerEdge R750")
  firmware        String?  // Firmware/BIOS version
  networkRole     String?  // router, switch, firewall, load_balancer, endpoint, printer, iot
  services        String   @default("[]") // JSON: [{port, protocol, service, version, banner}]
  openPorts       String   @default("[]") // JSON: [22, 80, 443, 3306]
  discoveryMethod String?  // scanner, manual, cloud_api, agent, cmdb_sync
  discoveredAt    DateTime? // When asset was first discovered by scanner
  ttl             Int?     // TTL value from network probe (for OS fingerprinting)
  // ── Phase 9: Asset Inventory Fields (Client Step 2) ──
  serialNumber      String?  // Hardware serial number (e.g., "SN-2024-WEB-0847")
  biosUuid          String?  // BIOS/UEFI UUID for physical host identification
  physicalLocation  String?  // Data center / rack / office (e.g., "DC-Mumbai-R12-U24")
  assetOwner        String?  // Team or individual responsible (e.g., "Platform Engineering")
  subnet            String?  // Network subnet (e.g., "10.0.1.0/24")
  vlan              String?  // VLAN ID (e.g., "VLAN-100")
  installedSoftware String   @default("[]") // JSON: [{name, version, vendor, installedAt}]
  userAccounts      String   @default("[]") // JSON: [{username, role, lastLogin, status}]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group       AssetGroup? @relation(fields: [groupId], references: [id])
  scanResults ScanResult[]
  assetTags   AssetTag[]

  @@index([tenantId])
  @@map("assets")
}

// ─── SCANS ───────────────────────────────────────────────────────
model Scan {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  type        String    // vulnerability, port, compliance, full
  status      String    @default("queued") // queued, running, completed, failed, cancelled
  targets     String    @default("[]") // JSON array of target IPs/ranges
  config      String    @default("{}") // JSON scan configuration
  progress    String    @default("{}") // JSON: { completedChecks: [], currentBatch: 0, totalBatches: N }
  startedAt   DateTime?
  completedAt DateTime?
  createdById String?
  scheduleCron String?  // cron expression for scheduled scans
  scanEngine  String   @default("builtin") // "builtin" | "nmap"
  nmapVersion String?  // e.g. "7.94" when nmap engine used
  rawOutput   String?  // Nmap XML output for audit evidence
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  results ScanResult[]
  targetCredentials ScanTargetCredential[]
  diffsAsBase       ScanDiff[]             @relation("DiffBaseScan")
  diffsAsNew        ScanDiff[]             @relation("DiffNewScan")

  @@index([tenantId])
  @@map("scans")
}

model ScanResult {
  id          String   @id @default(uuid())
  tenantId    String
  scanId      String
  assetId     String?
  severity    String   // critical, high, medium, low, info
  title       String
  description String?
  cveId       String?
  cvssScore   Float?
  status      String   @default("open") // open, acknowledged, resolved, false_positive
  remediation String?
  details     String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scan   Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  asset  Asset? @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@index([scanId])
  @@map("scan_results")
}

// ─── COMPLIANCE ──────────────────────────────────────────────────
model ComplianceFramework {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // GDPR, PCI DSS, HIPAA
  version     String   // e.g., "4.0", "2016/679"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  controls ComplianceControl[]

  @@unique([tenantId, name, version])
  @@map("compliance_frameworks")
}

model ComplianceControl {
  id            String   @id @default(uuid())
  tenantId      String
  frameworkId   String
  controlId     String   // e.g., "Art. 32", "Req. 6.1", "164.312(a)"
  title         String
  description   String?
  category      String?  // e.g., "Data Protection", "Access Control"
  status        String   @default("not_assessed")
  evidence      String   @default("[]") // JSON array of evidence items
  notes         String?
  lastAssessedAt DateTime?
  nextReviewAt  DateTime?
  assignedTo    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  framework ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  assessments ComplianceAssessment[]

  @@unique([frameworkId, controlId])
  @@index([tenantId])
  @@map("compliance_controls")
}

model ComplianceAssessment {
  id          String   @id @default(uuid())
  tenantId    String
  controlId   String
  assessorId  String?
  assessorType String  @default("manual") // manual, system
  status      String   // compliant, partially_compliant, non_compliant, not_applicable
  findings    String?
  evidence    String   @default("[]") // JSON
  remediationPlan String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  control ComplianceControl @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("compliance_assessments")
}

// ═══════════════════════════════════════════════════════════════════
// SIEM / SOC — Phase 10: Enterprise SIEM Enhancement
// ═══════════════════════════════════════════════════════════════════

// ─── SIEM EVENTS (ECS-Normalized) ───────────────────────────────
model SiemEvent {
  id        String   @id @default(uuid())
  tenantId  String

  // ── Core fields ──
  source    String   // firewall, ids, endpoint, cloud, application, edr, waf, identity, database, dns, scanner
  severity  String   // critical, high, medium, low, info
  category  String   // authentication, network, malware, policy_violation, system, process, dns, cloud_iam, data_exfil, lateral_movement, ransomware
  title     String
  details   String   @default("{}") // JSON — full ECS-normalized payload

  // ── Network fields (ECS) ──
  sourceIp    String?
  sourcePort  Int?
  destIp      String?
  destPort    Int?
  protocol    String?  // tcp, udp, icmp, http, https, dns
  direction   String?  // inbound, outbound, internal

  // ── Identity/Auth fields (ECS) ──
  userId       String?
  userName     String?
  userDomain   String?
  eventOutcome String? // success, failure
  eventAction  String? // login, logout, mfa_verify, privilege_escalation, account_created

  // ── Process fields (ECS) ──
  processName       String?
  processPid        Int?
  processParentName String?
  processExecutable String?
  hostName          String?
  hostIp            String?

  // ── Enrichment fields ──
  geoCountry       String?  // ISO country code
  geoCity          String?
  threatIntelHit   Boolean  @default(false)
  assetCriticality String?  // critical, high, medium, low

  // ── Metadata ──
  dataset  String?  // e.g., "auth.login", "network.flow", "process.start"
  module   String?  // e.g., "palo_alto", "crowdstrike", "aws_cloudtrail"
  logLevel String?  // debug, info, warning, error, critical
  raw      String?  // raw log line

  createdAt DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alerts SiemAlert[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, category])
  @@index([tenantId, severity])
  @@map("siem_events")
}

// ─── SIEM ALERTS (with Triage, MITRE ATT&CK, Scoring) ──────────
model SiemAlert {
  id           String    @id @default(uuid())
  tenantId     String
  ruleId       String?
  eventId      String?
  severity     String    // critical, high, medium, low
  title        String
  description  String?

  // ── Full lifecycle ──
  status         String    @default("open") // open, triaging, investigating, contained, resolved, closed, false_positive
  assignedTo     String?
  assignedToName String?

  // ── MITRE ATT&CK ──
  mitreAttackId  String?  // e.g., "T1110"
  mitreTactic    String?  // e.g., "Credential Access"
  mitreTechnique String?  // e.g., "Brute Force / Password Spray"

  // ── Scoring ──
  confidenceScore        Int?    // 0-100
  assetCriticalityWeight String? // from impacted asset
  priorityScore          Int?    // computed: severity * confidence * criticality

  // ── Case link ──
  incidentId String?

  // ── Investigation context ──
  impactedUsers   String  @default("[]") // JSON array
  impactedAssets  String  @default("[]") // JSON array
  relatedAlertIds String  @default("[]") // JSON array
  threatIntel     String  @default("{}") // JSON: { iocType, iocValue, source }

  // ── Timestamps ──
  acknowledgedAt DateTime?
  containedAt    DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule     SiemRule?     @relation(fields: [ruleId], references: [id])
  event    SiemEvent?    @relation(fields: [eventId], references: [id])
  incident SiemIncident? @relation(fields: [incidentId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, severity])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([incidentId])
  @@map("siem_alerts")
}

// ─── SIEM RULES (with MITRE ATT&CK & Tuning) ───────────────────
model SiemRule {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?

  // ── Detection engine ──
  ruleType    String   @default("correlation") // correlation, behavioral, threat_intel, anomaly
  condition   String   @default("{}") // JSON rule definition
  severity    String   @default("medium")
  isActive    Boolean  @default(true)

  // ── MITRE ATT&CK mapping ──
  mitreAttackId  String?  // e.g., "T1110"
  mitreTactic    String?  // e.g., "Credential Access"
  mitreTechnique String?  // e.g., "Brute Force / Password Spray"

  // ── Rule tuning ──
  confidenceLevel    Int       @default(75) // 0-100
  falsePositiveRate  Float     @default(0)
  truePositiveCount  Int       @default(0)
  falsePositiveCount Int       @default(0)
  lastTriggeredAt    DateTime?

  // ── Operational ──
  category    String?  // authentication, network, malware, process, cloud, data_exfil
  dataSources String   @default("[]") // JSON: ["endpoint", "firewall", "cloud"]
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alerts SiemAlert[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("siem_rules")
}

// ─── SIEM INCIDENTS (Case Management) ───────────────────────────
model SiemIncident {
  id          String   @id @default(uuid())
  tenantId    String

  // ── Core fields ──
  title       String
  description String?
  severity    String   // critical, high, medium, low
  status      String   @default("open") // open, investigating, contained, eradicated, recovered, closed
  priority    String   @default("medium") // critical, high, medium, low

  // ── Assignment ──
  assignedTo      String?
  assignedToName  String?
  escalatedBy     String?
  escalatedByName String?

  // ── Impact & Analysis ──
  impactSummary    String?
  impactedUsers    String  @default("[]") // JSON array
  impactedAssets   String  @default("[]") // JSON array
  rootCause        String?
  remediationSteps String  @default("[]") // JSON: [{step, status, assignee, completedAt}]

  // ── Timeline & Evidence ──
  timeline    String  @default("[]") // JSON: [{timestamp, action, actor, details}]
  evidence    String  @default("[]") // JSON: [{type, name, addedAt, addedBy}]

  // ── MITRE ATT&CK ──
  mitreTactics    String  @default("[]") // JSON array
  mitreTechniques String  @default("[]") // JSON array

  // ── Compliance & SLA ──
  complianceMapping String  @default("[]") // JSON: [{framework, control}]
  slaBreached       Boolean @default(false)

  // ── Timestamps ──
  detectedAt     DateTime
  acknowledgedAt DateTime?
  containedAt    DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alerts SiemAlert[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("siem_incidents")
}

// ─── AI ACTIONS ──────────────────────────────────────────────────
model AiAction {
  id           String    @id @default(uuid())
  tenantId     String
  type         String    // patch, firewall_rule, risk_override, siem_rule, scan
  title        String
  description  String?
  riskLevel    String    @default("medium") // low, medium, high
  status       String    @default("pending")
  config       String    @default("{}") // JSON action configuration
  approvedById String?
  approvedAt   DateTime?
  executedAt   DateTime?
  expiresAt    DateTime?
  result       String?   // JSON result of execution
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("ai_actions")
}

// ─── REPORTS ─────────────────────────────────────────────────────
model Report {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  type        String    // vulnerability, compliance, executive, technical, custom
  template    String?   // template identifier
  config      String    @default("{}") // JSON report configuration
  status      String    @default("generating")
  data        String    @default("{}") // JSON report data
  createdById String?
  scheduleCron String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("reports")
}

// ═══════════════════════════════════════════════════════════════════
// ENTERPRISE SSO & SCIM (Phase 6)
// ═══════════════════════════════════════════════════════════════════

// ─── SSO PROVIDERS (per-tenant OAuth configuration) ─────────────
model SSOProvider {
  id               String   @id @default(uuid())
  tenantId         String
  providerType     String   // google, azure_ad, okta
  name             String   // Display name: "Google Workspace", "Okta SSO"
  clientId         String   // Encrypted at rest (AES-256-GCM)
  clientSecret     String   // Encrypted at rest (AES-256-GCM)
  issuerUrl        String?  // OIDC issuer (e.g., https://accounts.google.com)
  authorizationUrl String?  // Override for non-standard providers
  tokenUrl         String?  // Override for non-standard providers
  userinfoUrl      String?  // Override for non-standard providers
  domains          String   @default("[]") // JSON: ["exargen.com"] — allowed email domains
  defaultRoleId    String?  // Auto-assign this role on JIT provisioning
  scopes           String   @default("openid profile email")
  isEnabled        Boolean  @default(false)
  autoProvision    Boolean  @default(true) // JIT user creation on first SSO login
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("SSOProviderCreator", fields: [createdById], references: [id])

  @@unique([tenantId, providerType])
  @@index([tenantId, isEnabled])
  @@map("sso_providers")
}

// ─── SCIM TOKENS (bearer tokens for SCIM API auth) ─────────────
model SCIMToken {
  id          String    @id @default(uuid())
  tenantId    String
  name        String    // "Okta SCIM Token", "Azure AD Sync"
  tokenHash   String    @unique  // bcrypt hash
  tokenPrefix String    // First 8 chars for display: "scim_abc1..."
  createdById String
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("SCIMTokenCreator", fields: [createdById], references: [id])

  @@index([tenantId, isActive])
  @@map("scim_tokens")
}

// ═══════════════════════════════════════════════════════════════════
// SCANNER CREDENTIAL VAULT (Phase 12C)
// ═══════════════════════════════════════════════════════════════════

// ─── CREDENTIAL VAULT (encrypted SSH/WinRM credentials) ─────────
model CredentialVault {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  description    String?
  credentialType String   // "ssh_password" | "ssh_key" | "winrm_password"
  username       String   // AES-256-GCM encrypted
  secret         String   // AES-256-GCM encrypted (password or SSH private key PEM)
  passphrase     String?  // AES-256-GCM encrypted (SSH key passphrase, optional)
  defaultPort    Int?     // null = protocol default (22 for SSH, 5985 for WinRM)
  winrmScheme    String?  // "http" | "https"
  sshKeyType     String?  // "rsa" | "ecdsa" | "ed25519"
  lastUsedAt     DateTime?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy             User?                  @relation("CredentialCreator", fields: [createdById], references: [id])
  scanTargetCredentials ScanTargetCredential[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("credential_vaults")
}

// ─── SCAN TARGET CREDENTIALS (maps targets to credentials) ──────
model ScanTargetCredential {
  id           String   @id @default(uuid())
  tenantId     String
  scanId       String
  target       String
  credentialId String
  createdAt    DateTime @default(now())

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scan       Scan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  credential CredentialVault @relation(fields: [credentialId], references: [id], onDelete: Restrict)

  @@unique([scanId, target])
  @@index([tenantId, scanId])
  @@map("scan_target_credentials")
}

// ─── SCAN DIFF (delta between two completed scans) ──────────────
model ScanDiff {
  id              String   @id @default(uuid())
  tenantId        String
  baseScanId      String
  newScanId       String
  computedAt      DateTime @default(now())
  newCount        Int      @default(0)
  resolvedCount   Int      @default(0)
  persistentCount Int      @default(0)
  changedCount    Int      @default(0)
  diffData        String   @default("{}") // JSON: { new, resolved, persistent, changed }

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  baseScan Scan   @relation("DiffBaseScan", fields: [baseScanId], references: [id], onDelete: Cascade)
  newScan  Scan   @relation("DiffNewScan", fields: [newScanId], references: [id], onDelete: Cascade)

  @@unique([baseScanId, newScanId])
  @@index([tenantId, newScanId])
  @@map("scan_diffs")
}
