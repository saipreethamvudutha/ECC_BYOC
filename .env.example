# ===========================================
# BYOC - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Database (Railway PostgreSQL) ─────────
# Get this from Railway dashboard → PostgreSQL → Connect → Connection String
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# ─── Authentication ────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-secure-random-string-min-32-chars"

# ─── App Config ────────────────────────────
NEXT_PUBLIC_APP_NAME="BYOC"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email (Resend) ──────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="BYOC <onboarding@resend.dev>"
